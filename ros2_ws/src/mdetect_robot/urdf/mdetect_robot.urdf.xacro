<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mdetect_robot">
  <xacro:property name="base_length" value="0.20"/>
  <xacro:property name="base_width" value="0.22"/>
  <xacro:property name="base_height" value="0.08"/>
  <xacro:property name="wheel_radius" value="0.04025"/>
  <xacro:property name="wheel_width" value="0.028"/>
  <xacro:property name="wheelbase" value="0.19"/>
  <xacro:property name="track" value="0.21"/>

  <material name="body"><color rgba="0.15 0.35 0.65 1"/></material>
  <material name="wheel"><color rgba="0.05 0.05 0.05 1"/></material>
  <material name="sensor"><color rgba="0.2 0.8 0.2 1"/></material>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/><child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual><origin xyz="0 0 ${base_height/2}"/><geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry><material name="body"/></visual>
    <collision><origin xyz="0 0 ${base_height/2}"/><geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry></collision>
    <inertial><origin xyz="0 0 ${base_height/2}"/><mass value="5.0"/><inertia ixx="0.025" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.04"/></inertial>
  </link>

  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_wheel_link">
      <visual><origin rpy="1.5708 0 0"/><geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry><material name="wheel"/></visual>
      <collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry></collision>
      <inertial><mass value="0.25"/><inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0003"/></inertial>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/><child link="${name}_wheel_link"/>
      <origin xyz="${x} ${y} 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="front_left" x="${wheelbase/2}" y="${track/2}"/>
  <xacro:wheel name="front_right" x="${wheelbase/2}" y="${-track/2}"/>
  <xacro:wheel name="rear_right" x="${-wheelbase/2}" y="${-track/2}"/>
  <xacro:wheel name="rear_left" x="${-wheelbase/2}" y="${track/2}"/>

  <link name="laser">
    <visual><geometry><cylinder radius="0.035" length="0.035"/></geometry><material name="sensor"/></visual>
  </link>
  <joint name="laser_joint" type="fixed"><parent link="base_link"/><child link="laser"/><origin xyz="0.05 0 0.13" rpy="0 0 0"/></joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed"><parent link="base_link"/><child link="imu_link"/><origin xyz="0 0 0.08" rpy="0 0 0"/></joint>
</robot>
